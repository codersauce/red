fn log_view() {
    capture_git("log", [
        "log",
        "--graph",
        "--decorate",
        "--date=short",
        "--pretty=format:%H%x09%h%x09%ad%x09%an%x09%s",
        "-n",
        "200",
    ]);
}

fn open_worktree_items(output: String) {
    let items = [];
    let lines = red::split(output, "\n");
    let index = 0;
    while index < red::len(lines) && red::len(items) < 500 {
        let line = lines[index];
        if red::starts_with(line, "worktree ") {
            let path = red::slice(line, 9);
            items = red::push(items, PickerItem {
                id: path,
                label: path,
                kind: "GitWorktree",
                data: Json { menu_kind: "worktrees", value: path },
            });
        }
        index = index + 1;
    }
    items = red::push(items, PickerItem { id: "Cancel", label: "Cancel", kind: "Cancel" });
    open_items("Worktrees", items);
}

fn open_log_items(output: String) {
    let items = [];
    for line in red::split(output, "\n") {
        if red::trim(line) != "" {
            let clean = red::trim(line);
            let fields = red::split(clean, "\t");
            items = red::push(items, PickerItem {
                id: fields[0],
                label: fields[1] + " " + fields[4],
                kind: "GitCommit",
                detail: fields[2] + " " + fields[3],
                data: Json { menu_kind: "log-select", oid: fields[0] },
            });
        }
    }
    open_items("Git log", items);
}

fn start_rebase_plan(output: String) {
    let commits = [];
    let lines = red::split(output, "\n");
    let index = 0;
    while index < red::len(lines) && red::len(commits) < 500 {
        let line = lines[index];
        if red::trim(line) != "" {
            let fields = red::split(line, "\t");
            commits = red::push(commits, RebaseCommit {
                oid: fields[0],
                subject: fields[1],
            });
        }
        index = index + 1;
    }
    if red::len(commits) == 0 {
        return;
    }
    red::state_set("git_rebase_commits", commits);
    red::state_set("git_rebase_index", 0);
    red::state_set("git_rebase_todo", []);
    show_rebase_choice();
}

fn show_rebase_choice() {
    let commits = red::state("git_rebase_commits");
    let index = red::int(red::state("git_rebase_index"), 0);
    if index >= red::len(commits) {
        run_rebase_todo();
        return;
    }
    let commit = commits[index];
    let choices = ["pick", "edit", "drop", "Cancel rebase"];
    if index > 0 {
        choices = ["pick", "edit", "squash", "fixup", "drop", "Cancel rebase"];
    }
    open_choices("rebase-choice", red::slice(commit.oid, 0, 8) + " " + commit.subject, choices);
}

fn run_rebase_todo() {
    let todo = red::join(red::state("git_rebase_todo"), "\n") + "\n";
    let process_id = red::execute("SpawnProcess", Process {
        command: "git",
        args: ["rebase", "-i", red::string(red::state("git_rebase_base"), "HEAD~5")],
        cwd: red::string(red::state("git_root"), "."),
        env: Json {
            GIT_SEQUENCE_EDITOR: red::string(red::state("git_executable"), "red") + " --process-editor-replace",
            GIT_EDITOR: "true",
            RED_PROCESS_EDITOR_CONTENT: todo,
        },
    });
    red::on("process:" + process_id, action_finished);
}

fn menu_selected(item: PickerItem) {
    let value = red::string(item.id, "");
    if value == "Cancel" || value == "Close" {
        return;
    }
    let kind = red::string(item.data.menu_kind, "");

    if kind == "branch-menu" || red::starts_with(kind, "branches-") {
        branch_item_selected(kind, value);
    } else if kind == "tag-menu" || red::starts_with(kind, "tags-") {
        tag_item_selected(kind, value);
    } else if kind == "stash-menu" || kind == "stashes" {
        stash_item_selected(kind, value);
    } else if kind == "remote-menu" || kind == "remotes" {
        remote_item_selected(kind, value);
    } else if kind == "worktree-menu" || kind == "worktrees" {
        worktree_item_selected(kind, value);
    } else if kind == "reset-mode" {
        reset_mode_selected(value);
    } else if kind == "operation-menu" {
        operation_item_selected(value);
    } else if kind == "push-remote" {
        run_simple_git(["push", "--set-upstream", value, red::string(red::state("git_state").head, "")]);
    } else if kind == "log-select" || kind == "log-action" {
        log_item_selected(kind, item, value);
    } else if kind == "rebase-choice" {
        rebase_item_selected(value);
    }
}

fn branch_item_selected(kind: String, value: String) {
    if kind == "branch-menu" {
        if value == "Checkout" {
            capture_git("branches-checkout", ["for-each-ref", "--format=%(refname:short)", "refs/heads"]);
        } else if value == "Create" {
            open_prompt("branch-create", "New branch name", "");
        } else if value == "Rename current" {
            open_prompt("branch-rename", "Rename branch", red::string(red::state("git_state").head, ""));
        } else if value == "Delete" {
            capture_git("branches-delete", ["for-each-ref", "--format=%(refname:short)", "refs/heads"]);
        } else if value == "Merge" {
            capture_git("branches-merge", ["for-each-ref", "--format=%(refname:short)", "refs/heads"]);
        } else if value == "Rebase onto" {
            capture_git("branches-rebase", ["for-each-ref", "--format=%(refname:short)", "refs/heads"]);
        }
    } else if kind == "branches-checkout" {
        run_simple_git(["switch", value]);
    } else if kind == "branches-delete" {
        confirm_git("Delete branch", value, ["branch", "-d", value]);
    } else if kind == "branches-merge" {
        run_simple_git(["merge", "--no-edit", value]);
    } else if kind == "branches-rebase" {
        run_simple_git(["rebase", value]);
    }
}

fn tag_item_selected(kind: String, value: String) {
    if kind == "tag-menu" {
        if value == "Create lightweight" {
            open_prompt("tag-create", "Tag name", "");
        } else if value == "Create annotated" {
            open_prompt("tag-annotated-name", "Tag name", "");
        } else if value == "Delete" {
            capture_git("tags-delete", ["for-each-ref", "--format=%(refname:short)", "refs/tags"]);
        } else if value == "Push" {
            capture_git("tags-push", ["for-each-ref", "--format=%(refname:short)", "refs/tags"]);
        }
    } else if kind == "tags-delete" {
        confirm_git("Delete tag", value, ["tag", "-d", value]);
    } else if kind == "tags-push" {
        if value == "All tags" {
            run_simple_git(["push", "--tags"]);
        } else {
            run_simple_git(["push", "origin", "refs/tags/" + value]);
        }
    }
}

fn stash_item_selected(kind: String, value: String) {
    if kind == "stash-menu" {
        if value == "Push" {
            open_prompt("stash-push", "Stash message", "");
        } else if value == "Push including untracked" {
            run_simple_git(["stash", "push", "--include-untracked"]);
        } else {
            red::state_set("git_stash_action", red::lower(value));
            capture_git("stashes", ["stash", "list", "--format=%gd%x09%s"]);
        }
    } else {
        let ref = red::split(value, "\t")[0];
        let action = red::string(red::state("git_stash_action"), "apply");
        if action == "drop" {
            confirm_git("Drop stash", value, ["stash", action, ref]);
        } else {
            run_simple_git(["stash", action, ref]);
        }
    }
}

fn remote_item_selected(kind: String, value: String) {
    if kind == "remote-menu" {
        if value == "List" {
            red::state_set("git_remote_action", "list");
            capture_git("remotes", ["remote"]);
        } else if value == "Add" {
            open_prompt("remote-add-name", "Remote name", "origin");
        } else {
            red::state_set("git_remote_action", red::lower(value));
            capture_git("remotes", ["remote"]);
        }
    } else {
        if red::string(red::state("git_remote_action"), "") == "remove" {
            confirm_git("Remove remote", value, ["remote", "remove", value]);
        } else if red::string(red::state("git_remote_action"), "") == "rename" {
            red::state_set("git_remote_old", value);
            open_prompt("remote-rename-new", "New remote name", value);
        }
    }
}

fn worktree_item_selected(kind: String, value: String) {
    if kind == "worktree-menu" {
        if value == "List" {
            red::state_set("git_worktree_action", "list");
            capture_git("worktrees", ["worktree", "list", "--porcelain"]);
        } else if value == "Add" {
            open_prompt("worktree-add-path", "Worktree path", "");
        } else if value == "Prune" {
            confirm_git("Prune worktrees", "Remove stale worktree administrative records.", ["worktree", "prune"]);
        } else {
            red::state_set("git_worktree_action", red::lower(value));
            capture_git("worktrees", ["worktree", "list", "--porcelain"]);
        }
    } else {
        let action = red::string(red::state("git_worktree_action"), "");
        if action == "move" {
            red::state_set("git_worktree_old", value);
            open_prompt("worktree-move-destination", "Move worktree to", value);
        } else if action != "" {
            if action == "remove" {
                confirm_git("Remove worktree", value, ["worktree", action, value]);
            } else {
                run_simple_git(["worktree", action, value]);
            }
        }
    }
}

fn reset_mode_selected(value: String) {
    let args = ["reset", "--" + red::lower(value), red::string(red::state("git_reset_target"), "HEAD~1")];
    if value == "Hard" {
        confirm_git("Hard reset", "Working tree and index changes will be discarded.", args);
    } else {
        run_simple_git(args);
    }
}

fn operation_item_selected(value: String) {
    let operation = red::string(red::state("git_operation"), "");
    let action = red::lower(value);
    if action == "abort" {
        confirm_operation(operation, action);
    } else {
        run_operation_git(operation, action);
    }
}

fn log_item_selected(kind: String, item: PickerItem, value: String) {
    if kind == "log-select" {
        red::state_set("git_log_oid", item.data.oid);
        open_choices("log-action", item.label, ["Show details", "Cherry-pick", "Revert", "Create branch", "Create tag", "Cancel"]);
    } else {
        let oid = red::string(red::state("git_log_oid"), "");
        if value == "Show details" {
            capture_git("log-detail", ["show", "--stat", "--patch", "--color=never", oid]);
        } else if value == "Cherry-pick" {
            run_simple_git(["cherry-pick", oid]);
        } else if value == "Revert" {
            confirm_git("Revert commit", oid, ["revert", "--no-edit", oid]);
        } else if value == "Create branch" {
            open_prompt("log-branch-create", "Branch name", "");
        } else if value == "Create tag" {
            open_prompt("log-tag-create", "Tag name", "");
        }
    }
}

fn rebase_item_selected(value: String) {
    if value == "Cancel rebase" {
        return;
    }
    let commits = red::state("git_rebase_commits");
    let index = red::int(red::state("git_rebase_index"), 0);
    let commit = commits[index];
    red::state_set("git_rebase_todo", red::push(red::state("git_rebase_todo"), value + " " + commit.oid + " " + commit.subject));
    red::state_set("git_rebase_index", index + 1);
    show_rebase_choice();
}

fn render_error(message: String) {
    if red::state_bool("git_dashboard_open") {
        red::execute("UpdateWorkspace", "git-dashboard", WorkspaceModel {
            rows: [WorkspaceRow {
                id: "git-error",
                selectable: false,
                segments: [PanelSegment { text: message, style: warning_style() }],
            }],
        });
    }
}

fn normal_style() -> Json {
    let info = red::state("git_info");
    if info == red::null() {
        return Style { fg: red::null(), bg: red::null(), bold: false, italic: false };
    }
    let style = info.theme.style;
    if style == red::null() {
        return Style { fg: red::null(), bg: red::null(), bold: false, italic: false };
    }
    return style;
}
fn muted_style() -> Json {
    let info = red::state("git_info");
    if info == red::null() { return normal_style(); }
    let ui = info.theme.ui_style;
    if ui == red::null() { return normal_style(); }
    let style = ui.muted;
    if style == red::null() { return normal_style(); }
    return style;
}
fn heading_style() -> Json {
    let info = red::state("git_info");
    if info == red::null() {
        let style = normal_style();
        style.bold = true;
        return style;
    }
    let ui = info.theme.ui_style;
    if ui == red::null() {
        let style = normal_style();
        style.bold = true;
        return style;
    }
    let style = ui.popup_title;
    if style == red::null() { style = normal_style(); }
    style.bold = true;
    return style;
}
fn branch_style() -> Json { return heading_style(); }
fn success_style() -> Json {
    let style = normal_style();
    let info = red::state("git_info");
    if info == red::null() { return style; }
    let colors = info.theme.colors;
    if colors == red::null() { return style; }
    let color = colors["gitDecoration.addedResourceForeground"];
    if color != red::null() { style.fg = color; }
    return style;
}
fn warning_style() -> Json {
    let style = normal_style();
    let info = red::state("git_info");
    if info == red::null() { return style; }
    let colors = info.theme.colors;
    if colors == red::null() { return style; }
    let color = colors["gitDecoration.deletedResourceForeground"];
    if color != red::null() { style.fg = color; }
    return style;
}
fn section_style(section: String) -> Json {
    if section == "staged" { return success_style(); }
    if section == "conflicted" { return warning_style(); }
    return normal_style();
}

fn hunk_previous() { begin_hunk_action("previous"); }
fn hunk_next() { begin_hunk_action("next"); }
fn hunk_stage() { begin_hunk_action("stage"); }
fn hunk_unstage() { begin_hunk_action("unstage"); }
fn hunk_reset() { begin_hunk_action("reset"); }
fn submit_message() { red::request("GetBufferText", commit_buffer_text); }
fn cancel_message() { finish_commit_scratch(false, ""); }

fn commit_menu() {
    red::execute("OpenPicker", "Commit", [
        PickerItem { id: "create", label: "Create commit", kind: "Created" },
        PickerItem { id: "amend", label: "Amend commit", kind: "Amend" },
        PickerItem { id: "no-edit", label: "Amend without editing", kind: "Amend" },
        PickerItem { id: "cancel", label: "Cancel", kind: "Cancel" },
    ], PickerOptions {}, PickerHandlers {
        selected: commit_choice,
    });
}

fn commit_choice(item: PickerItem) {
    if item.id == "cancel" {
        return;
    }
    if item.id == "no-edit" {
        red::state_set("git_confirm_mode", "commit-no-edit");
        open_confirmation("Amend commit", "Rewrite HEAD while keeping its message.");
        return;
    }
    red::state_set("git_commit_mode", item.id);
    red::request("GetEditorState", commit_snapshot_loaded);
}

fn commit_snapshot_loaded(snapshot: Json) {
    red::state_set("git_commit_snapshot", snapshot);
    let text = red::string(red::state("git_commit_retry_text"), "");
    red::state_set("git_commit_retry_text", "");
    red::request("OpenScratchBuffer", commit_scratch_opened, "[Git Commit].gitcommit", text);
}

fn commit_scratch_opened(event: Json) {
    red::state_set("git_commit_buffer", red::int(event.buffer_index, -1));
    close_dashboard();
}

fn restore_finished(result: Json) {
    if !red::bool(result.restored, false) {
        red::log("Git scratch restore did not restore editor state", result.warnings);
    }
}

fn commit_buffer_text(event: Json) {
    if red::int(red::state("git_commit_buffer"), -1) < 0 {
        return;
    }
    finish_commit_scratch(true, red::string(event.text, ""));
}

fn finish_commit_scratch(submit: bool, text: String) {
    let index = red::int(red::state("git_commit_buffer"), -1);
    if index < 0 {
        return;
    }
    red::execute("CloseScratchBuffer", index);
    let snapshot = red::state("git_commit_snapshot");
    if snapshot != red::null() {
        red::request("RestoreEditorState", restore_finished, snapshot);
    }
    red::state_set("git_commit_buffer", -1);
    if submit {
        let message = red::trim(text);
        if message != "" {
            let mode = red::string(red::state("git_commit_mode"), "");
            if mode == "amend" {
                confirm_commit(mode, message);
            } else {
                run_commit(mode, message);
            }
        }
    }
}

fn run_commit(mode: String, message: String) {
    let args = ["commit"];
    if mode == "amend" || mode == "--amend" {
        args = red::push(args, "--amend");
    }
    if mode == "--amend" {
        args = red::push(args, "--no-edit");
    } else {
        args = red::push(args, "--cleanup=strip");
        args = red::push(args, "-F");
        args = red::push(args, "-");
    }
    let process_id = red::execute("SpawnProcess", Process {
        command: "git",
        args: args,
        stdin: message + "\n",
        cwd: red::string(red::state("git_root"), "."),
    });
    red::state_set("git_commit_retry_text", message);
    red::on("process:" + process_id, commit_finished);
}

fn commit_finished(event: Json) {
    if event["type"] != "exit" {
        return;
    }
    if red::int(event.code, 1) == 0 {
        red::state_set("git_commit_retry_text", "");
        force_refresh();
        return;
    }
    red::request("GetEditorState", commit_snapshot_loaded);
}

fn begin_hunk_action(action: String) {
    red::state_set("git_hunk_action", action);
    red::request("GetWindows", hunk_windows_loaded);
}

fn hunk_windows_loaded(result: Json) {
    let path = "";
    let buffer_index = -1;
    for window in result.windows {
        if red::bool(window.active, false) {
            path = red::string(window.buffer_path, "");
            buffer_index = red::int(window.buffer_index, -1);
        }
    }
    if path == "" {
        return;
    }
    red::state_set("git_hunk_path", path);
    red::state_set("git_hunk_disk_path", path);
    red::state_set("git_hunk_path", repository_path(path));
    red::state_set("git_hunk_buffer", buffer_index);
    red::state_set("git_hunk_selection", red::null());
    let action = red::string(red::state("git_hunk_action"), "");
    if action == "stage" {
        red::request("GetBufferText", hunk_buffer_text);
        return;
    }
    spawn_hunk_diff(action);
}

fn hunk_buffer_text(event: Json) {
    red::state_set("git_hunk_unsaved", true);
    red::state_set("git_hunk_patch", "");
    let path = red::string(red::state("git_hunk_path"), "");
    let disk_path = red::string(red::state("git_hunk_disk_path"), "");
    let process_id = red::execute("SpawnProcess", Process {
        command: "git",
        args: ["diff", "--no-index", "--no-ext-diff", "--unified=3", "--", disk_path, "-"],
        stdin: red::string(event.text, ""),
        raw_output: true,
        cwd: red::string(red::state("git_root"), "."),
    });
    red::on("process:" + process_id, hunk_diff_event);
}

fn spawn_hunk_diff(action: String) {
    red::state_set("git_hunk_unsaved", false);
    red::state_set("git_hunk_patch", "");
    let args = ["diff"];
    if action == "unstage" {
        args = red::push(args, "--cached");
    }
    args = red::push(args, "--no-ext-diff");
    if action == "next" || action == "previous" {
        args = red::push(args, "--unified=0");
    } else {
        args = red::push(args, "--unified=3");
    }
    args = red::push(args, "--");
    args = red::push(args, red::string(red::state("git_hunk_path"), ""));
    let process_id = red::execute("SpawnProcess", Process {
        command: "git",
        args: args,
        raw_output: true,
        cwd: red::string(red::state("git_root"), "."),
    });
    red::on("process:" + process_id, hunk_diff_event);
}

fn repository_path(path: String) -> String {
    let root = red::string(red::state("git_root"), ".");
    if red::starts_with(path, root + "/") {
        return red::slice(path, red::len(root) + 1);
    }
    return path;
}

fn hunk_diff_event(event: Json) {
    if event["type"] == "stdout" {
        let patch = event.line;
        if red::state_bool("git_hunk_unsaved") {
            patch = normalize_unsaved_patch(patch, red::string(red::state("git_hunk_path"), ""));
        }
        red::state_set("git_hunk_patch", patch);
    }
    if event["type"] == "exit" {
        if red::state_bool("git_hunk_unsaved") && red::string(red::state("git_hunk_patch"), "") == "" {
            spawn_hunk_diff(red::string(red::state("git_hunk_action"), ""));
            return;
        }
        red::request("GetSelection", hunk_selection_loaded);
    }
}

fn normalize_unsaved_patch(patch: String, path: String) -> String {
    let lines = [];
    for line in red::split(patch, "\n") {
        let normalized = line;
        if red::starts_with(line, "diff --git ") {
            normalized = "diff --git a/" + path + " b/" + path;
        } else if red::starts_with(line, "--- ") {
            normalized = "--- a/" + path;
        } else if red::starts_with(line, "+++ ") {
            normalized = "+++ b/" + path;
        }
        lines = red::push(lines, normalized);
    }
    return red::join(lines, "\n");
}

fn hunk_selection_loaded(selection: Json) {
    red::state_set("git_hunk_selection", selection);
    red::request("GetCursorPosition", hunk_cursor_loaded);
}

fn hunk_cursor_loaded(cursor: Json) {
    let action = red::string(red::state("git_hunk_action"), "");
    let patch = red::string(red::state("git_hunk_patch"), "");
    if action == "next" || action == "previous" {
        navigate_patch(patch, red::int(cursor.y, 0), action == "next");
        return;
    }
    let selected = "";
    let selection = red::state("git_hunk_selection");
    if selection != red::null() && red::int(selection.buffer_index, -1) == red::int(red::state("git_hunk_buffer"), -2) {
        let start_line = red::int(selection.start.y, 0);
        let end_line = red::int(selection.end.y, start_line);
        if end_line < start_line {
            let swap = start_line;
            start_line = end_line;
            end_line = swap;
        }
        selected = patch_for_line_range(patch, start_line, end_line);
    } else {
        selected = patch_for_hunk(patch, red::int(cursor.y, 0));
    }
    if selected == "" {
        red::execute("Print", "No Git hunk under cursor");
        return;
    }
    red::state_set("git_hunk_patch", selected);
    if action == "reset" {
        red::execute("OpenPicker", "Reset hunk", [
            PickerItem { id: "cancel", label: "Cancel", kind: "Cancel" },
            PickerItem { id: "proceed", label: "Proceed", kind: "Destructive" },
        ], PickerOptions { status: "This cannot be undone by Red." }, PickerHandlers {
            selected: reset_confirmed,
        });
    } else {
        apply_hunk(action, selected);
    }
}

fn reset_confirmed(item: PickerItem) {
    if item.id == "proceed" {
        apply_hunk("reset", red::string(red::state("git_hunk_patch"), ""));
    }
}

fn navigate_patch(patch: String, cursor_line: i32, forward: bool) {
    let starts = hunk_starts(patch);
    if red::len(starts) == 0 {
        print_hunk_boundary(forward);
        return;
    }
    let target = -1;
    if forward {
        for line in starts {
            if line > cursor_line && target == -1 {
                target = line;
            }
        }
    } else {
        for line in starts {
            if line < cursor_line {
                target = line;
            }
        }
    }
    if target == -1 {
        print_hunk_boundary(forward);
        return;
    }
    red::execute("SetCursorPosition", 0, target);
}

fn print_hunk_boundary(forward: bool) {
    if forward {
        red::execute("Print", "No next Git hunk");
    } else {
        red::execute("Print", "No previous Git hunk");
    }
}

fn hunk_starts(patch: String) -> Json {
    let starts = [];
    for line in red::split(patch, "\n") {
        if red::starts_with(line, "@@ ") {
            starts = red::push(starts, hunk_start(line));
        }
    }
    return starts;
}

fn hunk_start(header: String) -> i32 {
    let fields = red::split(header, " ");
    let plus = fields[2];
    let range = red::split(red::slice(plus, 1), ",");
    return red::int(range[0], 1) - 1;
}

fn patch_for_hunk(patch: String, cursor_line: i32) -> String {
    let header = [];
    let selected = [];
    let current = [];
    let current_start = -1;
    let current_end = -1;
    for line in red::split(patch, "\n") {
        if red::starts_with(line, "@@ ") {
            if current_start >= 0 && cursor_line >= current_start && cursor_line <= current_end {
                selected = current;
            }
            current = [line];
            current_start = hunk_start(line);
            let fields = red::split(line, " ");
            let range = red::split(red::slice(fields[2], 1), ",");
            let count = 1;
            if red::len(range) > 1 {
                count = red::int(range[1], 1);
            }
            current_end = current_start + count - 1;
        } else if current_start >= 0 {
            current = red::push(current, line);
        } else {
            header = red::push(header, line);
        }
    }
    if current_start >= 0 && cursor_line >= current_start && cursor_line <= current_end {
        selected = current;
    }
    if red::len(selected) == 0 {
        return "";
    }
    for line in selected {
        header = red::push(header, line);
    }
    return red::join(header, "\n");
}

fn patch_for_line_range(patch: String, start_line: i32, end_line: i32) -> String {
    let common_header = [];
    let selected_hunks = [];
    let current = [];
    let old_start = 0;
    let new_start = 0;
    for line in red::split(patch, "\n") {
        if red::starts_with(line, "@@ ") {
            if red::len(current) > 0 {
                let selected = selected_hunk(current, old_start, new_start, start_line, end_line);
                if selected != "" {
                    selected_hunks = red::push(selected_hunks, selected);
                }
            }
            current = [line];
            let fields = red::split(line, " ");
            old_start = range_start(fields[1]);
            new_start = range_start(fields[2]);
        } else if red::len(current) > 0 {
            current = red::push(current, line);
        } else {
            common_header = red::push(common_header, line);
        }
    }
    if red::len(current) > 0 {
        let selected = selected_hunk(current, old_start, new_start, start_line, end_line);
        if selected != "" {
            selected_hunks = red::push(selected_hunks, selected);
        }
    }
    if red::len(selected_hunks) == 0 {
        return "";
    }
    let result = red::join(common_header, "\n");
    for hunk in selected_hunks {
        if result != "" {
            result = result + "\n";
        }
        result = result + hunk;
    }
    return result;
}

fn range_start(field: String) -> i32 {
    let range = red::split(red::slice(field, 1), ",");
    return red::int(range[0], 1);
}

fn selected_hunk(lines: Json, old_start: i32, new_start: i32, start_line: i32, end_line: i32) -> String {
    let output = [];
    let new_line = new_start - 1;
    let index = 1;
    while index < red::len(lines) {
        let line = red::string(lines[index], "");
        if !red::starts_with(line, "+") && !red::starts_with(line, "-") {
            output = red::push(output, line);
            if red::starts_with(line, " ") {
                new_line = new_line + 1;
            }
            index = index + 1;
            continue;
        }
        let removed = [];
        while index < red::len(lines) && red::starts_with(red::string(lines[index], ""), "-") {
            removed = red::push(removed, lines[index]);
            index = index + 1;
        }
        let addition_start = new_line;
        let added = [];
        while index < red::len(lines) && red::starts_with(red::string(lines[index], ""), "+") {
            added = red::push(added, lines[index]);
            new_line = new_line + 1;
            index = index + 1;
        }
        let addition_end = addition_start;
        if red::len(added) > 0 {
            addition_end = addition_start + red::len(added) - 1;
        }
        let selected = false;
        if red::len(added) > 0 {
            selected = addition_start <= end_line && addition_end >= start_line;
        } else {
            selected = addition_start >= start_line && addition_start <= end_line + 1;
        }
        if selected {
            for removed_line in removed {
                output = red::push(output, removed_line);
            }
            for added_line in added {
                output = red::push(output, added_line);
            }
        } else {
            for removed_line in removed {
                output = red::push(output, " " + red::slice(red::string(removed_line, ""), 1));
            }
        }
    }
    let has_change = false;
    let old_count = 0;
    let new_count = 0;
    for line in output {
        let text = red::string(line, "");
        if red::starts_with(text, "+") || red::starts_with(text, "-") {
            has_change = true;
        }
        if red::starts_with(text, " ") || red::starts_with(text, "-") {
            old_count = old_count + 1;
        }
        if red::starts_with(text, " ") || red::starts_with(text, "+") {
            new_count = new_count + 1;
        }
    }
    if !has_change {
        return "";
    }
    let result = "@@ -" + old_start + "," + old_count + " +" + new_start + "," + new_count + " @@";
    for line in output {
        result = result + "\n" + red::string(line, "");
    }
    return result;
}

fn apply_hunk(action: String, patch: String) {
    let previous = red::string(red::state("git_apply_check_process"), "");
    if previous != "" {
        red::execute("KillProcess", previous);
    }
    red::state_set("git_apply_check_action", action);
    red::state_set("git_apply_check_patch", patch);
    let args = apply_hunk_args(action);
    args = red::push(args, "--check");
    let process_id = red::execute("SpawnProcess", Process {
        command: "git",
        args: args,
        stdin: patch + "\n",
        cwd: red::string(red::state("git_root"), "."),
    });
    red::state_set("git_apply_check_process", process_id);
    red::on("process:" + process_id, apply_hunk_check_finished);
}

fn apply_hunk_args(action: String) -> Json {
    let args = ["apply"];
    if action == "stage" || action == "unstage" {
        args = red::push(args, "--cached");
    }
    if action == "unstage" || action == "reset" {
        args = red::push(args, "--reverse");
    }
    args = red::push(args, "--unidiff-zero");
    args = red::push(args, "-");
    return args;
}

fn apply_hunk_check_finished(event: Json) {
    if event.process_id != red::state("git_apply_check_process") || event["type"] != "exit" {
        return;
    }
    red::state_set("git_apply_check_process", "");
    if red::int(event.code, 1) != 0 {
        red::execute("Print", "Git rejected the selected patch; refresh and try again");
        return;
    }
    let action = red::string(red::state("git_apply_check_action"), "");
    let patch = red::string(red::state("git_apply_check_patch"), "");
    let process_id = red::execute("SpawnProcess", Process {
        command: "git",
        args: apply_hunk_args(action),
        stdin: patch + "\n",
        cwd: red::string(red::state("git_root"), "."),
    });
    red::on("process:" + process_id, action_finished);
}

fn deactivate() {
    cancel_detail_timer();
    for job in red::state("git_operation_jobs") {
        red::execute("KillProcess", job.id);
    }
    red::state_set("git_operation_jobs", []);
    let refresh_timer = red::string(red::state("git_refresh_timer"), "");
    if refresh_timer != "" {
        red::execute("CancelTimeout", refresh_timer);
    }
    let poll_timer = red::string(red::state("git_poll_timer"), "");
    if poll_timer != "" {
        red::execute("CancelTimeout", poll_timer);
    }
    red::state_set("git_refresh_timer", "");
    red::state_set("git_poll_timer", "");
    if red::string(red::state("git_watch_path"), "") != "" {
        red::execute("UnwatchDirectory", 1502);
    }
    red::execute("ClearGutterSigns", "git-signs");
    red::execute("CloseWorkspace", "git-dashboard");
}
