pub fn activate() {
    red::add_command("Agent", prompt);
    red::add_command("AgentStart", start);
    red::add_command("AgentPrompt", prompt);
    red::add_command("AgentCancel", cancel);
    red::add_command("AgentClear", clear_conversation);
    red::add_command("AgentClose", close_conversation);
    red::add_command("AgentNew", new_conversation);
    red::add_command("AgentReview", review);
    red::add_command("AgentHistory", history);
    red::on("agent:session_created", session_created);
    red::on("agent:update", update);
    red::on("agent:activity", activity);
    red::on("agent:turn_started", turn_started);
    red::on("agent:completed", completed);
    red::on("agent:cancelled", cancelled);
    red::on("agent:error", failed);
    red::on("agent:session_lost", session_lost);
    red::on("agent:proposals_changed", proposals_changed);
    red::on("agent:proposal_applied", proposals_changed);
    red::on("agent:proposal_conflict", proposal_conflict);
    red::on("agent:permission_requested", permission_requested);
    red::on("agent:transcript_restored", transcript_restored);
    red::on("workspace:event:agent-review", review_event);
    red::on("workspace:event:agent-history", history_event);
    red::on("picker:selected:801", permission_selected);
    red::on("picker:cancelled:801", permission_cancelled);
    red::on("composer:submitted:802", prompt_submitted);
    red::on("composer:cancelled:802", prompt_cancelled);
    red::on("picker:selected:803", setup_selected);
    red::on("picker:cancelled:803", setup_cancelled);
    red::on("agent:credential_ready", setup_ready);
    red::on("agent:backend_ready", setup_ready);
    red::on("timeout:callback", stream_timeout);
    red::on("panel:event:agent-conversation", panel_event);
    red::state_set("agent_session_id", "");
    red::state_set("agent_panel_created", false);
    red::state_set("agent_panel_open", false);
    red::state_set("agent_review_open", false);
    red::state_set("agent_detail", [[PanelSegment { text: "Select a hunk to inspect it", style: muted_style() }]]);
    red::state_set("agent_permission_request_id", "");
    red::state_set("agent_prompt_history", []);
    red::state_set("agent_pending_prompt", "");
    red::state_set("agent_pending_prompt_is_replay", false);
    red::state_set("agent_proposal_notice", false);
    red::state_set("agent_transcript", "");
    red::state_set("agent_transcript_blocks", []);
    red::state_set("agent_streaming", false);
    red::state_set("agent_turn_active", false);
    red::state_set("agent_prompt_queue", []);
    red::state_set("agent_recap_pending", false);
    red::state_set("agent_cancelled_session_id", "");
    red::state_set("agent_stream_block_id", "");
    red::state_set("agent_block_generation", 0);
    red::state_set("agent_stream_timer", "");
    red::state_set("agent_stream_delta", "");
    red::state_set("agent_stream_trimmed", false);
    red::state_set("agent_history_open", false);
    red::state_set("agent_history_detail", [[PanelSegment { text: "Select a transaction", style: muted_style() }]]);
}

fn start() {
    red::request("GetConfig", cwd_loaded, "cwd");
}

fn cwd_loaded(result: Json) {
    red::execute("AgentNewSession", red::string(result.value, "."));
}

fn session_created(event: Json) {
    let previous_session_id = red::string(red::state("agent_session_id"), "");
    let pending = red::string(red::state("agent_pending_prompt"), "");
    let replay = red::state_bool("agent_pending_prompt_is_replay");
    red::state_set("agent_session_id", event.session_id);
    if previous_session_id != event.session_id || (pending != "" && replay) {
        red::state_set("agent_turn_active", false);
    }
    if previous_session_id != event.session_id {
        red::state_set("agent_cancelled_session_id", "");
    }
    if previous_session_id != "" && previous_session_id != event.session_id {
        red::execute("AgentCloseSession", previous_session_id);
    }
    ensure_conversation_panel();
    render_conversation();
    red::execute("Print", "Agent session started");
    refresh_proposals();
    if pending != "" {
        red::state_set("agent_pending_prompt", "");
        red::state_set("agent_pending_prompt_is_replay", false);
        if replay {
            red::state_set("agent_turn_active", true);
            red::execute("AgentPrompt", event.session_id, pending);
        } else {
            submit_prompt(pending);
        }
    }
}

fn prompt() {
    if red::string(red::state("agent_session_id"), "") != "" {
        ensure_conversation_panel();
    }
    red::request("GetStorage", prompt_history_loaded, "prompt_history");
}

fn ensure_conversation_panel() {
    if !red::state_bool("agent_panel_created") {
        red::execute("CreateTextPanel", "agent-conversation", PanelConfig {
            side: "right",
            width: 52,
            title: "Agent",
            composer: Json { placeholder: "Ask a follow-up…", rows: 3 },
            header_actions: [
                Json { id: "clear", label: "Clear", compact_label: "C" },
                Json { id: "new", label: "New", compact_label: "N" },
                Json { id: "close", label: "×", compact_label: "×" },
            ],
        });
        red::state_set("agent_panel_created", true);
        red::state_set("agent_panel_open", true);
        return;
    }
    if !red::state_bool("agent_panel_open") {
        red::execute("SetPanelVisible", "agent-conversation", true);
        red::state_set("agent_panel_open", true);
    }
}

fn prompt_history_loaded(result: Json) {
    let history = [];
    if result.value != red::null() {
        for entry in result.value {
            let text = red::string(entry, "");
            if red::trim(text) != "" && !red::contains(history, text) && red::len(history) < 50 {
                history = red::push(history, text);
            }
        }
    }
    red::state_set("agent_prompt_history", history);
    red::execute("OpenAgentComposer", "Agent prompt", 802, red::string(red::state("agent_pending_prompt"), ""), history);
}

fn prompt_submitted(prompt: Json) {
    let text = red::string(prompt, "");
    if red::trim(text) == "" {
        return;
    }
    let history = [text];
    for entry in red::state("agent_prompt_history") {
        if entry != text && red::len(history) < 50 {
            history = red::push(history, entry);
        }
    }
    red::state_set("agent_prompt_history", history);
    red::execute("SetStorage", "prompt_history", history);
    red::state_set("agent_proposal_notice", false);
    if red::state("agent_session_id") == "" {
        red::state_set("agent_pending_prompt", text);
        red::state_set("agent_pending_prompt_is_replay", false);
        start();
        return;
    }
    submit_prompt(text);
}

fn submit_prompt(text: String) {
    if red::trim(text) == "" {
        return;
    }
    if red::state_bool("agent_turn_active") {
        let queue = red::state("agent_prompt_queue");
        if red::len(queue) >= 16 {
            red::execute("Print", "Agent follow-up queue is full");
            return;
        }
        queue = red::push(queue, text);
        red::state_set("agent_prompt_queue", queue);
        red::execute("SetTextPanelComposerState", "agent-conversation", true, "Working · " + red::len(queue) + " queued · Enter queues · ^C stops");
        red::execute("Print", "Agent turn is still running; follow-up queued (" + red::len(queue) + ")");
        return;
    }
    if red::string(red::state("agent_session_id"), "") == "" {
        red::state_set("agent_pending_prompt", text);
        red::state_set("agent_pending_prompt_is_replay", false);
        start();
        return;
    }
    dispatch_prompt(text);
}

fn dispatch_prompt(text: String) {
    let wire_text = text;
    if red::state_bool("agent_recap_pending") {
        let recap = red::string(red::state("agent_transcript"), "");
        if red::len(recap) > 6000 {
            recap = red::slice(recap, red::len(recap) - 6000);
        }
        if red::trim(recap) != "" {
            wire_text = "Previous conversation (the last turn was interrupted):\n" + recap + "\n\nFollow-up:\n" + text;
        }
        red::state_set("agent_recap_pending", false);
    }
    red::state_set("agent_turn_active", true);
    append_transcript("You", text);
    red::execute("AgentPrompt", red::state("agent_session_id"), wire_text);
}

fn turn_started(event: Json) {
    if !is_current_session_event(event) {
        return;
    }
    let queued = red::len(red::state("agent_prompt_queue"));
    let status = "Working · Enter queues · ^C stops";
    if queued > 0 {
        status = "Working · " + queued + " queued · Enter queues · ^C stops";
    }
    red::execute("SetTextPanelComposerState", "agent-conversation", true, status);
}

fn activity(event: Json) {
    if !is_current_session_event(event) {
        return;
    }
    let update = event.update;
    let label = red::string(update.title, "");
    if label == "" {
        label = red::string(update.status, "");
    }
    if label == "" {
        label = red::string(update.session_update, "Working");
    }
    red::execute("SetTextPanelComposerState", "agent-conversation", true, label + " · Enter queues · ^C stops");
}

fn panel_event(event: Json) {
    if event.action == "submit" {
        let text = red::string(event.text, "");
        if red::trim(text) != "" {
            prompt_submitted(text);
        }
    } else if event.action == "composer_focus" {
        red::execute("FocusTextPanelComposer", "agent-conversation");
    } else if event.action == "interrupt" {
        cancel();
    } else if event.action == "clear" {
        clear_conversation();
    } else if event.action == "new" {
        new_conversation();
    } else if event.action == "history" {
        history();
    } else if event.action == "close" {
        close_conversation();
    }
}

fn clear_conversation() {
    reset_stream_render();
    red::state_set("agent_transcript_blocks", []);
    red::execute("UpdateTextPanel", "agent-conversation", []);
    red::execute("SetTextPanelComposerState", "agent-conversation", true, "Conversation view cleared · context preserved");
}

fn reset_stream_render() {
    let timer = red::string(red::state("agent_stream_timer"), "");
    if timer != "" {
        red::execute("CancelTimeout", timer);
        red::state_set("agent_stream_timer", "");
    }
    red::state_set("agent_streaming", false);
    red::state_set("agent_stream_block_id", "");
    red::state_set("agent_stream_delta", "");
    red::state_set("agent_stream_trimmed", false);
}

fn close_conversation() {
    if red::state_bool("agent_panel_open") {
        red::execute("SetPanelVisible", "agent-conversation", false);
        red::state_set("agent_panel_open", false);
    }
    red::execute("FocusEditor");
}

fn new_conversation() {
    let session_id = red::string(red::state("agent_session_id"), "");
    if session_id != "" {
        red::execute("AgentCloseSession", session_id);
    }
    red::state_set("agent_session_id", "");
    red::state_set("agent_cancelled_session_id", "");
    red::state_set("agent_turn_active", false);
    red::state_set("agent_prompt_queue", []);
    red::state_set("agent_recap_pending", false);
    red::state_set("agent_pending_prompt", "");
    red::state_set("agent_pending_prompt_is_replay", false);
    red::state_set("agent_proposal_notice", false);
    clear_conversation();
    red::state_set("agent_transcript", "");
    red::execute("SetStorage", "transcript", "");
    red::execute("ClearTextPanelComposer", "agent-conversation");
    prompt();
}

fn prompt_cancelled(event: Json) {}

fn cancel() {
    let session_id = red::state("agent_session_id");
    if session_id != "" {
        red::execute("AgentCancel", session_id);
    }
}

fn update(event: Json) {
    if !is_current_session_event(event) {
        return;
    }
    let delta = red::string(event.text, "");
    if delta == "" {
        return;
    }

    let transcript = red::state("agent_transcript");
    let block_id = red::string(red::state("agent_stream_block_id"), "");
    if !red::state_bool("agent_streaming") {
        if transcript != "" && !red::ends_with(transcript, "\n") {
            transcript = transcript + "\n";
        }
        transcript = transcript + "Agent: ";

        let generation = red::int(red::state("agent_block_generation"), 0) + 1;
        block_id = "agent:" + generation;
        red::state_set("agent_block_generation", generation);
        red::state_set("agent_streaming", true);
        red::state_set("agent_stream_block_id", block_id);

        let blocks = red::state("agent_transcript_blocks");
        blocks = red::push(blocks, TextPanelBlock {
            id: block_id,
            kind: "agent",
            format: "markdown",
            text: "",
        });
        red::state_set("agent_transcript_blocks", blocks);
        render_conversation();
    }

    transcript = transcript + delta;
    if red::len(transcript) > 20000 {
        transcript = red::slice(transcript, red::len(transcript) - 20000);
    }
    red::state_set("agent_transcript", transcript);

    let blocks = red::state("agent_transcript_blocks");
    let updated = [];
    for block in blocks {
        if block.id == block_id {
            block.text = red::string(block.text, "") + delta;
        }
        updated = red::push(updated, block);
    }
    let bounded = bounded_transcript_blocks(updated, block_id);
    red::state_set("agent_transcript_blocks", bounded.blocks);
    if bounded.trimmed {
        red::state_set("agent_stream_trimmed", true);
    }
    red::state_set("agent_stream_delta", red::string(red::state("agent_stream_delta"), "") + delta);

    let timer = red::string(red::state("agent_stream_timer"), "");
    if timer != "" {
        red::execute("CancelTimeout", timer);
    }
    red::state_set("agent_stream_timer", red::execute("SetTimeout", 50));
}

fn completed(event: Json) {
    if !is_current_session_event(event) {
        return;
    }
    red::state_set("agent_turn_active", false);
    let session_id = red::string(event.session_id, "");
    let stop_reason = red::string(event.stop_reason, "end_turn");
    if stop_reason == "end_turn" {
        finish_agent_turn();
    }
    if session_id != "" && (stop_reason == "cancelled" || session_id == red::string(red::state("agent_cancelled_session_id"), "")) {
        red::execute("AgentCloseSession", session_id);
        red::state_set("agent_session_id", "");
        red::state_set("agent_cancelled_session_id", "");
        red::state_set("agent_recap_pending", true);
    }
    if stop_reason == "end_turn" {
        red::execute("SetTextPanelComposerState", "agent-conversation", true, "Ready · Enter sends · ^J adds a line");
        submit_next_queued();
        return;
    }
    append_transcript("System", "Agent stopped: " + stop_reason);
    red::execute("Print", "Agent stopped: " + stop_reason);
    submit_next_queued();
}

fn submit_next_queued() {
    let queue = red::state("agent_prompt_queue");
    if red::len(queue) == 0 {
        return;
    }
    let next = queue[0];
    let remaining = [];
    let index = 0;
    for entry in queue {
        if index > 0 {
            remaining = red::push(remaining, entry);
        }
        index = index + 1;
    }
    red::state_set("agent_prompt_queue", remaining);
    let text = red::string(next, "");
    if red::string(red::state("agent_session_id"), "") == "" {
        red::state_set("agent_pending_prompt", text);
        red::state_set("agent_pending_prompt_is_replay", false);
        start();
        return;
    }
    dispatch_prompt(text);
}

fn cancelled(event: Json) {
    if !is_current_session_event(event) {
        return;
    }
    let session_id = red::string(event.session_id, "");
    if session_id != "" {
        red::state_set("agent_cancelled_session_id", session_id);
    }
    if !red::state_bool("agent_turn_active") && session_id != "" {
        red::execute("AgentCloseSession", session_id);
        red::state_set("agent_session_id", "");
        red::state_set("agent_cancelled_session_id", "");
        red::state_set("agent_recap_pending", true);
    }
    red::execute("Print", "Agent cancellation requested");
    red::execute("SetTextPanelComposerState", "agent-conversation", true, "Stopping · follow-ups remain queued");
}

fn failed(event: Json) {
    if !is_current_session_event(event) {
        return;
    }
    if red::string(event.session_id, "") == "" && red::state_bool("agent_turn_active") {
        red::execute("Print", "Agent setup failed while a turn is active: " + event.message);
        return;
    }
    red::state_set("agent_turn_active", false);
    let session_id = red::string(event.session_id, "");
    if session_id != "" && session_id == red::string(red::state("agent_cancelled_session_id"), "") {
        red::execute("AgentCloseSession", session_id);
        red::state_set("agent_session_id", "");
        red::state_set("agent_cancelled_session_id", "");
        red::state_set("agent_recap_pending", true);
    }
    append_transcript("Error", event.message);
    if red::len(red::state("agent_prompt_queue")) > 0 {
        submit_next_queued();
        return;
    }
    if red::string(red::state("agent_pending_prompt"), "") != "" || red::state("agent_session_id") == "" {
        red::execute("Print", "Agent unavailable: " + event.message + ". Choose a setup action; your prompt is preserved");
        red::execute("OpenDynamicPicker", "Set up agent", 803, [
            PickerItem { id: "openai", label: "Use an OpenAI API key (reviewable edits)" },
            PickerItem { id: "codex", label: "Use installed Codex (reviewable edits)" },
            PickerItem { id: "retry", label: "Retry the saved prompt" },
        ], PickerOptions {
            placeholder: "Choose how to start the agent",
            status: "Enter selects; Escape keeps the saved prompt",
            presentation: "compact",
        });
    } else {
        red::execute("Print", "Agent error: " + event.message);
    }
}

fn session_lost(event: Json) {
    let session_id = red::string(red::state("agent_session_id"), "");
    let attempted = red::string(event.prompt, "");
    if !is_current_session_event(event) && (session_id != "" || attempted == "") {
        return;
    }
    red::state_set("agent_turn_active", false);
    if session_id != "" {
        red::execute("AgentArchiveSession", session_id);
        red::state_set("agent_recap_pending", true);
    }
    red::state_set("agent_session_id", "");
    red::state_set("agent_cancelled_session_id", "");
    if attempted != "" {
        red::state_set("agent_pending_prompt", attempted);
        red::state_set("agent_pending_prompt_is_replay", true);
        red::execute("Print", "ACP adapter stopped; retrying the saved prompt");
        start();
    } else if red::string(red::state("agent_pending_prompt"), "") != "" {
        failed(Json { message: "ACP adapter stopped" });
    } else {
        red::execute("Print", "ACP adapter stopped. Press Space A to start a new session");
    }
}

fn setup_selected(item: Json) {
    if item.id == "openai" {
        red::execute("AgentOpenApiKeyPrompt");
    } else if item.id == "codex" {
        red::execute("AgentUseCodex");
    } else if item.id == "retry" {
        start();
    }
}

fn setup_cancelled(event: Json) {
    red::execute("Print", "Agent prompt saved. Press Space A when ready to retry");
}

fn setup_ready(event: Json) {
    if red::string(red::state("agent_pending_prompt"), "") != "" {
        start();
    }
}

fn finish_agent_turn() {
    if !red::state_bool("agent_streaming") {
        return;
    }
    let transcript = red::state("agent_transcript");
    if !red::ends_with(transcript, "\n") {
        transcript = transcript + "\n";
    }
    if red::len(transcript) > 20000 {
        transcript = red::slice(transcript, red::len(transcript) - 20000);
    }
    red::state_set("agent_transcript", transcript);
    red::state_set("agent_streaming", false);
    let block_id = red::string(red::state("agent_stream_block_id"), "");
    red::state_set("agent_stream_block_id", "");
    let timer = red::string(red::state("agent_stream_timer"), "");
    if timer != "" {
        red::execute("CancelTimeout", timer);
        red::state_set("agent_stream_timer", "");
    }
    red::execute("SetStorage", "transcript", transcript);
    flush_stream(block_id);
}

fn append_transcript(role: String, text: String) {
    let transcript = red::state("agent_transcript");
    if red::state_bool("agent_streaming") {
        if !red::ends_with(transcript, "\n") {
            transcript = transcript + "\n";
        }
        red::state_set("agent_streaming", false);
        let timer = red::string(red::state("agent_stream_timer"), "");
        if timer != "" {
            red::execute("CancelTimeout", timer);
            red::state_set("agent_stream_timer", "");
        }
        red::state_set("agent_stream_block_id", "");
        red::state_set("agent_stream_delta", "");
        red::state_set("agent_stream_trimmed", false);
    }
    transcript = transcript + role + ": " + text + "\n";
    if red::len(transcript) > 20000 {
        transcript = red::slice(transcript, red::len(transcript) - 20000);
    }
    red::state_set("agent_transcript", transcript);
    red::execute("SetStorage", "transcript", transcript);

    let generation = red::int(red::state("agent_block_generation"), 0) + 1;
    red::state_set("agent_block_generation", generation);
    let kind = "text";
    if role == "You" {
        kind = "user";
    } else if role == "Error" {
        kind = "error";
    }
    let blocks = red::state("agent_transcript_blocks");
    blocks = red::push(blocks, TextPanelBlock {
        id: kind + ":" + generation,
        kind: kind,
        format: "plain",
        text: text,
    });
    let bounded = bounded_transcript_blocks(blocks, "");
    red::state_set("agent_transcript_blocks", bounded.blocks);
    render_conversation();
}

fn stream_timeout(event: Json) {
    if event.timer_id != red::state("agent_stream_timer") {
        return;
    }
    red::state_set("agent_stream_timer", "");
    red::execute("SetStorage", "transcript", red::state("agent_transcript"));
    flush_stream(red::string(red::state("agent_stream_block_id"), ""));
}

fn flush_stream(block_id: String) {
    let delta = red::string(red::state("agent_stream_delta"), "");
    let trimmed = red::state_bool("agent_stream_trimmed");
    red::state_set("agent_stream_delta", "");
    red::state_set("agent_stream_trimmed", false);
    if trimmed {
        render_conversation();
    } else if delta != "" {
        red::execute("AppendTextPanel", "agent-conversation", block_id, delta);
    }
}

fn transcript_restored(event: Json) {
    let transcript = red::string(event.transcript, "");
    let blocks = legacy_transcript_blocks(transcript);
    let generation = red::len(blocks);
    let bounded = bounded_transcript_blocks(blocks, "");
    red::state_set("agent_transcript", transcript);
    red::state_set("agent_transcript_blocks", bounded.blocks);
    red::state_set("agent_block_generation", generation);
    red::state_set("agent_streaming", false);
    red::state_set("agent_stream_block_id", "");
    red::state_set("agent_stream_delta", "");
    red::state_set("agent_stream_trimmed", false);
    render_conversation();
}

fn render_conversation() {
    let blocks = red::state("agent_transcript_blocks");
    if red::len(blocks) == 0 {
        blocks = [TextPanelBlock {
            id: "empty",
            kind: "text",
            format: "plain",
            text: "No messages yet. Press a to focus the composer or Space A for a new prompt.",
        }];
    }
    red::execute("UpdateTextPanel", "agent-conversation", blocks);
}

fn legacy_transcript_blocks(transcript: String) -> Json {
    let blocks = [];
    let index = 0;
    let kind = "";
    let format = "plain";
    let text = "";
    let lines = red::split(transcript, "\n");
    let line_index = 0;

    for line in lines {
        line_index = line_index + 1;
        if line == "" && line_index == red::len(lines) {
            continue;
        }
        if line == "System: Agent stopped: end_turn" {
            continue;
        }

        let next_kind = "";
        let next_format = "plain";
        let prefix = 0;
        if red::starts_with(line, "You: ") {
            next_kind = "user";
            prefix = 5;
        } else if red::starts_with(line, "Agent: ") {
            next_kind = "agent";
            next_format = "markdown";
            prefix = 7;
        } else if red::starts_with(line, "Error: ") {
            next_kind = "error";
            prefix = 7;
        } else if red::starts_with(line, "System: ") {
            next_kind = "text";
            prefix = 8;
        }

        if next_kind != "" {
            if kind != "" {
                blocks = red::push(blocks, TextPanelBlock {
                    id: kind + ":" + index,
                    kind: kind,
                    format: format,
                    text: text,
                });
            }
            index = index + 1;
            kind = next_kind;
            format = next_format;
            text = red::slice(line, prefix);
        } else {
            if kind == "" {
                index = index + 1;
                kind = "text";
                format = "plain";
            } else {
                text = text + "\n";
            }
            text = text + line;
        }
    }

    if kind != "" {
        blocks = red::push(blocks, TextPanelBlock {
            id: kind + ":" + index,
            kind: kind,
            format: format,
            text: text,
        });
    }
    return blocks;
}

fn bounded_transcript_blocks(blocks: Json, keep_id: String) -> Json {
    let total = 0;
    for block in blocks {
        total = total + red::len(red::string(block.text, ""));
    }
    if total <= 20000 {
        return Json { blocks: blocks, trimmed: false };
    }

    let excess = total - 20000;
    let bounded = [];
    let block_index = 0;
    for block in blocks {
        block_index = block_index + 1;
        let text = red::string(block.text, "");
        let length = red::len(text);
        if excess >= length && block.id != keep_id && block_index < red::len(blocks) {
            excess = excess - length;
            continue;
        }
        if excess > 0 {
            let cut = excess;
            if cut > length {
                cut = length;
            }
            block.text = red::slice(text, cut);
            excess = excess - cut;
        }
        bounded = red::push(bounded, block);
    }
    return Json { blocks: bounded, trimmed: true };
}

fn review() {
    red::state_set("agent_review_open", true);
    red::execute("OpenWorkspace", "agent-review", WorkspaceConfig {
        title: "Agent proposals",
        detail_ratio: 58,
        min_two_pane_width: 88,
    });
    refresh_proposals();
}

fn refresh_proposals() {
    if !red::state_bool("agent_review_open") {
        return;
    }
    red::request("AgentProposals", render_proposals, red::state("agent_session_id"));
}

fn render_proposals(result: Json) {
    let rows = [];
    for file in result.files {
        let status = " " + red::len(file.hunks) + " hunks";
        let status_style = muted_style();
        if file.conflict {
            status = " conflict";
            status_style = warning_style();
        }
        rows = red::push(rows, WorkspaceRow {
            id: "file:" + file.session_id + ":" + file.path,
            selectable: true,
            segments: [PanelSegment { text: file.path, style: heading_style() }],
            right_segments: [PanelSegment {
                text: status,
                style: status_style,
            }],
            data: Json { session_id: file.session_id, path: file.path, hunk_id: "", conflict: file.conflict },
        });
        if file.conflict {
            rows = red::push(rows, WorkspaceRow {
                id: "conflict:" + file.session_id + ":" + file.path,
                selectable: false,
                depth: 1,
                segments: [PanelSegment { text: file.message, style: warning_style() }],
            });
        } else {
            for hunk in file.hunks {
                rows = red::push(rows, WorkspaceRow {
                    id: "hunk:" + file.session_id + ":" + hunk.id,
                    selectable: true,
                    depth: 1,
                    segments: [PanelSegment {
                        text: "chars " + hunk.old_start + ".." + hunk.old_end,
                        style: normal_style(),
                    }],
                    data: Json {
                        session_id: file.session_id,
                        path: file.path,
                        hunk_id: hunk.id,
                        old_text: hunk.old_text,
                        new_text: hunk.new_text,
                        conflict: false,
                    },
                });
            }
        }
    }
    if result.error != red::null() {
        rows = red::push(rows, WorkspaceRow {
            id: "error",
            selectable: false,
            segments: [PanelSegment { text: result.error, style: warning_style() }],
        });
    } else if red::len(rows) == 0 {
        rows = red::push(rows, WorkspaceRow {
            id: "empty",
            selectable: false,
            segments: [PanelSegment { text: "No pending proposals", style: success_style() }],
        });
    }
    red::execute("UpdateWorkspace", "agent-review", WorkspaceModel {
        header: [PanelSegment { text: "Review before any buffer or disk change", style: muted_style() }],
        rows: rows,
        detail: red::state("agent_detail"),
        footer: [PanelSegment {
            text: "a accept hunk  A accept file  r reject hunk  R reject file  q close",
            style: muted_style(),
        }],
    });
}

fn review_event(event: Json) {
    if event.action == "q" || event.action == "escape" {
        red::state_set("agent_review_open", false);
        red::execute("CloseWorkspace", "agent-review");
        return;
    }
    let row = event.row;
    if row == red::null() || row.data.path == red::null() {
        return;
    }
    if event.action == "up" || event.action == "down" || event.action == "page_up" || event.action == "page_down" {
        show_proposal_detail(row);
    } else if event.action == "a" {
        red::execute("AgentAcceptProposal", row.data.session_id, row.data.path, row.data.hunk_id);
    } else if event.action == "A" {
        red::execute("AgentAcceptProposal", row.data.session_id, row.data.path, "");
    } else if event.action == "r" {
        red::execute("AgentRejectProposal", row.data.session_id, row.data.path, row.data.hunk_id);
    } else if event.action == "R" {
        red::execute("AgentRejectProposal", row.data.session_id, row.data.path, "");
    }
}

fn show_proposal_detail(row: Json) {
    if row.data.hunk_id == "" {
        return;
    }
    let detail = [];
    for line in red::split(row.data.old_text, "\n") {
        detail = red::push(detail, [PanelSegment { text: "- " + line, style: warning_style() }]);
    }
    for line in red::split(row.data.new_text, "\n") {
        detail = red::push(detail, [PanelSegment { text: "+ " + line, style: success_style() }]);
    }
    red::state_set("agent_detail", detail);
    refresh_proposals();
}

fn proposals_changed(event: Json) {
    if !is_current_session_event(event) && !red::state_bool("agent_review_open") {
        return;
    }
    refresh_proposals();
    if !red::state_bool("agent_review_open") && !red::state_bool("agent_proposal_notice") {
        red::request("AgentProposals", proposals_ready, red::state("agent_session_id"));
    }
}

fn proposals_ready(result: Json) {
    let files = red::len(result.files);
    if files == 0 || red::state_bool("agent_review_open") || red::state_bool("agent_proposal_notice") {
        return;
    }
    let hunks = 0;
    for file in result.files {
        hunks = hunks + red::len(file.hunks);
    }
    red::state_set("agent_proposal_notice", true);
    red::execute("Print", "Agent changes ready: " + files + " files, " + hunks + " hunks. Use :AgentReview to review before applying");
}

fn proposal_conflict(event: Json) {
    red::execute("Print", "Agent proposal conflicts with current buffer: " + event.path);
    refresh_proposals();
}

fn history() {
    red::state_set("agent_history_open", true);
    red::execute("OpenWorkspace", "agent-history", WorkspaceConfig {
        title: "Attributed edit history",
        detail_ratio: 58,
        min_two_pane_width: 88,
    });
    refresh_history();
}

fn refresh_history() {
    if red::state_bool("agent_history_open") {
        red::request("EditHistory", render_history);
    }
}

fn render_history(result: Json) {
    let rows = [];
    for entry in result.entries {
        let origin = entry.origin.kind;
        if origin == "agent" {
            origin = "agent " + entry.origin.session_id + "/" + entry.origin.turn_id;
        }
        let current_marker = "  ";
        if entry.current { current_marker = "* "; }
        rows = red::push(rows, WorkspaceRow {
            id: "transaction:" + entry.transaction_id,
            selectable: true,
            segments: [
                PanelSegment { text: current_marker, style: heading_style() },
                PanelSegment { text: entry.label, style: normal_style() },
            ],
            right_segments: [PanelSegment { text: origin, style: muted_style() }],
            data: Json { transaction_id: entry.transaction_id, edits: entry.edits },
        });
    }
    if red::len(rows) == 0 {
        rows = red::push(rows, WorkspaceRow {
            id: "empty",
            selectable: false,
            segments: [PanelSegment { text: "No edit transactions", style: muted_style() }],
        });
    }
    red::execute("UpdateWorkspace", "agent-history", WorkspaceModel {
        rows: rows,
        detail: red::state("agent_history_detail"),
        footer: [PanelSegment { text: "r safe revert  q close", style: muted_style() }],
    });
}

fn history_event(event: Json) {
    if event.action == "q" || event.action == "escape" {
        red::state_set("agent_history_open", false);
        red::execute("CloseWorkspace", "agent-history");
        return;
    }
    let row = event.row;
    if row == red::null() || row.data.transaction_id == red::null() {
        return;
    }
    if event.action == "r" {
        red::execute("RevertTransaction", row.data.transaction_id);
        refresh_history();
        return;
    }
    if event.action == "up" || event.action == "down" || event.action == "page_up" || event.action == "page_down" {
        let detail = [];
        for edit in row.data.edits {
            detail = red::push(detail, [PanelSegment { text: "- " + edit.old_text, style: warning_style() }]);
            detail = red::push(detail, [PanelSegment { text: "+ " + edit.new_text, style: success_style() }]);
        }
        red::state_set("agent_history_detail", detail);
        refresh_history();
    }
}

fn permission_requested(event: Json) {
    if !is_current_session_event(event) {
        return;
    }
    red::state_set("agent_permission_request_id", event.request_id);
    let items = [];
    for option in event.options {
        items = red::push(items, PickerItem {
            id: option.option_id,
            label: option.name,
            kind: option.kind,
            annotation: option.option_id,
            detail: "ACP permission option " + option.option_id,
            data: Json { option_id: option.option_id },
        });
    }
    red::execute("OpenDynamicPicker", "Agent permission", 801, items, PickerOptions {
        placeholder: "Choose an exact option from the agent",
        status: red::len(items) + " options",
        presentation: "compact",
    });
}

fn permission_selected(item: Json) {
    red::execute(
        "AgentPermissionResponse",
        red::state("agent_permission_request_id"),
        item.data.option_id
    );
    red::state_set("agent_permission_request_id", "");
}

fn is_current_session_event(event: Json) -> bool {
    let session_id = red::string(event.session_id, "");
    return session_id == "" || session_id == red::string(red::state("agent_session_id"), "");
}

fn permission_cancelled(event: Json) {
    red::execute("AgentPermissionResponse", red::state("agent_permission_request_id"), "");
    red::state_set("agent_permission_request_id", "");
}

fn normal_style() -> Json {
    return Style { fg: red::null(), bg: red::null(), bold: false, italic: false };
}
fn muted_style() -> Json { return normal_style(); }
fn heading_style() -> Json {
    let style = normal_style();
    style.bold = true;
    return style;
}
fn success_style() -> Json { return normal_style(); }
fn warning_style() -> Json {
    let style = normal_style();
    style.bold = true;
    return style;
}

fn deactivate() {
    let session_id = red::string(red::state("agent_session_id"), "");
    if session_id != "" {
        red::execute("AgentCloseSession", session_id);
    }
    red::state_set("agent_session_id", "");
    red::state_set("agent_cancelled_session_id", "");
    red::state_set("agent_review_open", false);
    red::state_set("agent_permission_request_id", "");
    let timer = red::string(red::state("agent_stream_timer"), "");
    if timer != "" {
        red::execute("CancelTimeout", timer);
        red::state_set("agent_stream_timer", "");
    }
}
